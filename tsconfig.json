{
  "compilerOptions": {
    "jsx": "react",
    "noEmit" : true,
    "checkJs": true,
    "allowJs": true,
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node"
  },
  "include": ["**/*.js",
              "**/*/.jsx"],
  "exclude": ["node_modules"]
}